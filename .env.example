GMAIL_ADDRESS=your@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
B2B_LABEL=B2B_INQUIRY
SLACK_WEBHOOK_DEALS=https://hooks.slack.com/services/...
SLACK_WEBHOOK_ERRORS=https://hooks.slack.com/services/...
DIRECTOR_NAME=이름
DIRECTOR_EMAIL=your@gmail.com
ANTIEGG_CEO=대표자명
ANTIEGG_BIZ_NO=000-00-00000
ANTIEGG_PHONE=02-0000-0000
ANTIEGG_EMAIL=your@gmail.com
ANTIEGG_ADDR=서울시 ...
# ngrok 정적 도메인 (계정당 1개 무료 — dashboard.ngrok.com/domains 에서 확인)
# 설정 시 server.sh가 --url=$NGROK_DOMAIN 으로 호출해 매 재시작 동일 URL 보장
# 미설정 시 ngrok이 매번 다른 random URL 발급
NGROK_DOMAIN=your-static.ngrok-free.dev

# 클라이언트가 접근할 수 있는 앱 공개 URL (서명 링크 이메일에 사용)
# server.sh가 ngrok 기동 후 자동 갱신
APP_BASE_URL=https://your-static.ngrok-free.dev
